AltLabelStructDecl(struct,attrs,getters,dispatchMethods) ::= <<

pub struct <struct.escapedName>\<'input> {
	context: ParserContext,
	<attrs:{a | <a>,
}>	ph:PhantomData\<&'input str>
}


// AltLabelStructDecl
impl\<'input> <struct.escapedName>\<'input>{
	fn new(ctx: &dyn <currentRule.name; format="cap">ContextAttrs\<'input>) -> <currentRule.name; format="cap">\<'input>  {
			<currentRule.name; format="cap">ContextAll::<struct.escapedName>(
				<if(contextSuperClass)><contextSuperClass><else>BaseParserRuleContext<endif>::copy_from(ctx,<struct.escapedName>Ext{
					<!base:<currentRule.name; format="cap">Context{..*base}!>
					<!<struct.attrs:{a | <a.escapedName>:None,}>!>
					<struct.tokenDecls:{a | <a.escapedName>:None, }>
        			<struct.tokenTypeDecls:{a | <a.escapedName>:-1, }>
        			<struct.tokenListDecls:{a | <a.escapedName>:Vec::new(), }>
        			<struct.ruleContextDecls:{a | <a.escapedName>:None, }>
        			<struct.ruleContextListDecls:{a | <a.escapedName>:Vec::new(), }>
        			base: ctx.borrow().clone(),
        			ph:PhantomData
        			<!<struct.ctorAttrs:{a | <a.escapedName> }; separator=",\n">!>
				})
			)
	}
}
>>

ContextTokenGetterDecl(t) ::= <<
/// Retrieves first TerminalNode corresponding to token <t.name>
/// Returns `None` if there is no child corresponding to token <t.name>
fn <t.name>(&self) -> Option\<TerminalNode\<'input,<parser.name>ContextType>\> {
	self.get_token(<parser.grammarName>_<t.name>, 0)
}
>>