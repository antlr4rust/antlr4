// 	}>	ph:PhantomData\<&'input str>
// }
 
// impl\<'input> <struct.escapedName>\<'input>{
// 	fn new(parent: Option\<dyn <parser.name>Context\<'input> + 'input>, invoking_state: i32<ctorAttrs:{a | , <a>}>) -> <struct.escapedName>\<'input> {
// 		<struct.attributeDecls:{a | let mut _init_<a.escapedName> = <rustTypeInitMap.(a.type)>;
// 		 }>
// 		 <struct.ctorAttrs:{a | _init_<a.escapedName> = <a.escapedName>;
// 		 }>
// 		<if(struct.provideCopyFrom)><struct.escapedName>All::Error(<endif>
// 			<struct.escapedName> {
// 			<!<attrs:{a | <a.escapedName>:None,}>!>
// 				<struct.tokenDecls:{a | <a.escapedName>: None, }>
